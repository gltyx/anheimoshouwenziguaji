<technique vs="PBRLitSolid" ps="PBRLitSolid" vsdefines="NORMALMAP" psdefines="DIFFMAP NORMALMAP PBR IBL">
    <pass name="base" vsdefines="AO" psdefines="AMBIENT AO" srgbsoftresolve="true" />
    <pass name="litbase" vsdefines="AO" psdefines="AMBIENT AO" srgbsoftresolve="true" />
    <pass name="light" vsdefines="AO" psdefines="AO" depthtest="equal" depthwrite="false" blend="add" srgbsoftresolve="true" />
    <pass name="material" psdefines="MATERIAL" depthtest="equal" depthwrite="false" />
    <pass name="depth" vs="Depth" ps="Depth" psexcludes="PACKEDNORMAL" />
    <pass name="shadow" vs="Shadow" ps="Shadow" psexcludes="PACKEDNORMAL" />
    <!-- 默认贴图 -->
	<texture unit="normal" name="Textures/DefaultNormal.tga" />
    <!-- 默认参数 -->
    <parameter name="MatDiffColor" value="1 1 1 1" />
    <parameter name="MatSpecColor" value="0.5 0.5 0.5 1" />
    <parameter name="MatEmissiveColor" value="0 0 0" />
    <parameter name="Metallic" value="0" />
    <parameter name="Roughness" value="0.5" />
    <parameter name="TintColor" value="0 0 0 0" /> 
</technique>
