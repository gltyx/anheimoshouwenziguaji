<technique vs="LitSolid" ps="LitSolid" psdefines="DIFFMAP">
    <pass name="base" psdefines="AMBIENT NORMALMAP" srgbsoftresolve="true" />
    <pass name="litbase" vsdefines="NORMALMAP" psdefines="AMBIENT NORMALMAP SPECMAP" srgbsoftresolve="true" />
    <pass name="light" vsdefines="NORMALMAP" psdefines="NORMALMAP SPECMAP" depthtest="equal" depthwrite="false" blend="add" srgbsoftresolve="true" />
    <pass name="prepass" vsdefines="NORMALMAP" psdefines="PREPASS NORMALMAP SPECMAP" />
    <pass name="material" psdefines="MATERIAL SPECMAP" depthtest="equal" depthwrite="false" />
    <pass name="deferred" vsdefines="NORMALMAP" psdefines="DEFERRED NORMALMAP SPECMAP" />
    <pass name="depth" vs="Depth" ps="Depth" psexcludes="PACKEDNORMAL" />
    <pass name="shadow" vs="Shadow" ps="Shadow" psexcludes="PACKEDNORMAL" />
    <parameter name="MatDiffColor" value="0.6 0.6 0.6 1" />
    <parameter name="MatSpecColor" value="0.5 0.5 0.5 16" />
    <parameter name="MatEmissiveColor" value="0 0 0" />
    <parameter name="MatEnvMapColor" value="0 0 0" />
</technique>
