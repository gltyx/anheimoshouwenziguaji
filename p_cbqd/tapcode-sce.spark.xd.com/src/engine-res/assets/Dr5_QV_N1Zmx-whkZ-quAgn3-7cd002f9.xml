<renderpath finalCopy="false" zPrepass="true" sightStencilMask="224">
    <!-- clear color:fog depth:1.0 stencil:0 -->
    <command type="clear" color="fog" depth="1.0" stencil="0" linkDepth="depth_buffer" />

    <!-- static mesh predraw - resolve to framebuffer -->
    <command type="staticmeshpredraw" pass="framebuffer" />

    <!-- alphatest pre z-pass -->
    <command type="scenepass" pass="depth" renderMask="2" highPriorityColorWrite="false" />

    <!-- opaque -->
    <command type="scenepass" pass="base" vertexlights="true" metadata="base" renderMask="1" />
    <command type="forwardlights" pass="light" renderMask="1" />
    <command type="scenepass" pass="postopaque" renderMask="1" />

    <!-- no blend litalpha -->
    <command type="scenepass" pass="alphanoblend" />

    <!-- alphatest -->
    <command type="scenepass" pass="base" vertexlights="true" metadata="base" renderMask="2" ignorePassResolve="true" highPriorityDepthTest="equal" />
    <command type="forwardlights" pass="light" renderMask="2" ignorePassResolve="true" highPriorityDepthTest="equal" />
    <command type="scenepass" pass="alpha" vertexlights="true" sort="backtofront" metadata="alpha" renderMask="2" ignorePassResolve="true" highPriorityDepthTest="equal" />    
    <!-- palnnershadow - alpha -->
    <command type="planershadow" pass="planershadow" renderMask="4" />
    <!-- innerstroke -->
    <command type="scenepass" pass="innerstroke" renderMask="7" >
        <parameter name="StrokeWidth" value="2" />
    </command>

    <!-- outstroke -->
    <command type="scenepass" pass="outstroke" renderMask="7" >
        <parameter name="StrokeWidth" value="7" />
    </command>

    <command type="clear" stencil="224"/>
    <command type="sightmask" pass="circle" marktostencil="true" vs="Sight/SightMaskCircle" ps="Sight/SightMaskCircle" stencilpass="ref" stencilref="31" highPriorityColorWrite="false" highPriorityDepthWrite="false" highPriorityDepthTest="always"/>
    <command type="sightmask" pass="base" marktostencil="true" vs="Sight/SightMask" ps="Sight/SightMask" stencilcompare="less" vsdefines="INSTANCED" stencilpass="ref" stencilref="31" highPriorityColorWrite="false" highPriorityDepthWrite="false" highPriorityDepthTest="always"/>
    <command type="sightmask" pass="skill" marktostencil="true" vs="Sight/SightMaskSkill" ps="Sight/SightMaskSkill" stencilpass="ref"  stencilref="31" highPriorityColorWrite="false" highPriorityDepthWrite="false" highPriorityDepthTest="always"/>
    <!-- opaque post sight -->
    <command type="scenepass" pass="base" vertexlights="true" metadata="base" renderMask="1" ignorePassResolve="true" postsight="true" highPriorityStencilTest="true" stencilcompare="equal"  stencilrmask="224"/>
    <command type="forwardlights" pass="light" renderMask="1" ignorePassResolve="true" postsight="true" highPriorityStencilTest="true" stencilcompare="equal"  stencilrmask="224"/>
    <command type="scenepass" pass="postopaque" renderMask="1" ignorePassResolve="true" postsight="true" highPriorityStencilTest="true" stencilcompare="equal"  stencilrmask="224"/>

    <!-- XRay -->
    <command type="scenepass" pass="xray" renderMask="7" >
        <parameter name="FresnelColor" value="0.27 0.94 0.94 0.4" />
    </command>
    <!-- alphatest post sight -->
    <command type="scenepass" pass="base" vertexlights="true" metadata="base" renderMask="2" ignorePassResolve="true" highPriorityDepthTest="equal" postsight="true" highPriorityStencilTest="true" stencilcompare="equal"  stencilrmask="224" />
    <command type="forwardlights" pass="light" renderMask="2" ignorePassResolve="true" highPriorityDepthTest="equal" postsight="true" highPriorityStencilTest="true" stencilcompare="equal"  stencilrmask="224"  />
    <command type="scenepass" pass="alpha" vertexlights="true" sort="backtofront" metadata="alpha" renderMask="2" ignorePassResolve="true" highPriorityDepthTest="equal"  postsight="true" highPriorityStencilTest="true" stencilcompare="equal"  stencilrmask="224"  />
    <!-- innerstroke -->
    <command type="scenepass" pass="innerstroke" renderMask="7" ignorePassResolve="true" postsight="true" highPriorityStencilTest="true" stencilcompare="equal" stencilrmask="224" stencilref="224" >
        <parameter name="StrokeWidth" value="2" />
    </command>
    <!-- outstroke -->
    <command type="scenepass" pass="outstroke" renderMask="7" ignorePassResolve="true" postsight="true" highPriorityColorWrite="false" highPriorityStencilTest="true" stencilcompare="notequal" stencilpass="ref" stencilrmask="224" stencilwmask="31" >
        <parameter name="StrokeWidth" value="7" />
    </command>
    <!-- alpha -->
    <command type="scenepass" pass="alpha" vertexlights="true" sort="backtofront" metadata="alpha" renderMask="4" />
    <command type="scenepass" pass="postalpha" sort="backtofront" renderMask="4" />
    <!-- alpha post sight -->
    <command type="scenepass" pass="alpha" vertexlights="true" sort="backtofront" metadata="alpha" renderMask="4" ignorePassResolve="true" postsight="true" highPriorityStencilTest="true" stencilcompare="equal"  stencilrmask="224"   />
    <command type="scenepass" pass="postalpha" sort="backtofront" renderMask="4" ignorePassResolve="true" postsight="true" highPriorityStencilTest="true"  stencilcompare="equal"  stencilrmask="224"  />
  
    <!-- static mesh predraw - resolve to texture -->
    <command type="staticmeshpredraw" pass="texture" />

    <!-- highlight -->
    <command type="scenepass" pass="outsurface" renderMask="7" />

    <!-- highlight -->
    <command type="scenepass" pass="outsurface" renderMask="7" postsight="true" ignorePassResolve="true" highPriorityStencilTest="true" stencilcompare="equal" stencilref="224" stencilrmask="224"/>

    <!-- volumetric light - alpha -->
    <command type="volumetriclight" vs="Volumetric/VolumetricLight" ps="Volumetric/VolumetricLight" vsdefines="BILLBOARD" psdefines="" blend="addalpha">
        <texture unit="diffuse" name="depth_buffer" />
    </command>

    <command type="sightmask" pass="soft" blend="alpha" vs="Sight/SightMaskSoft" ps="Sight/SightMaskSoft" highPriorityColorWrite="true" highPriorityDepthWrite="false" highPriorityDepthTest="always" highPriorityStencilTest="true" stencilcompare="equal" stencilref="224" stencilrmask="224"/>
    <command type="sightmask" pass="blend" blend="alpha" vs="Sight/SightMaskBlend" ps="Sight/SightMaskBlend" highPriorityStencilTest="true" stencilcompare="equal" stencilref="31" stencilrmask="224" highPriorityColorWrite="true" highPriorityDepthWrite="false" highPriorityDepthTest="always"/>

    <!-- postprocess -->
    <postprocess name="EngineRes/PostProcess/GamePostProcess.xml" />
</renderpath>