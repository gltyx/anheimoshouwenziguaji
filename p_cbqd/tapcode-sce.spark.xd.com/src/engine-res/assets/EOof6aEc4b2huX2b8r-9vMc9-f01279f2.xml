<renderpath>
    <command type="clear" color="fog" depth="1.0" stencil="0" linkDepth="depth_buffer" />
    <command type="scenepass" pass="base" vertexlights="true" metadata="base" />
    <command type="forwardlights" pass="light" />
    <command type="scenepass" pass="postopaque" />
    <command type="scenepass" pass="alphanoblend" />
    <command type="scenepass" pass="refract">
        <texture unit="env" name="viewport" />
    </command>
    <command type="scenepass" pass="alpha" vertexlights="true" sort="backtofront" metadata="alpha" />
    <command type="scenepass" pass="postalpha" sort="backtofront" />

    <command type="scenepass" pass="outsurface" blend="alpha" >
        <parameter name="SurfaceColor" value="0.0 1.0 0.3 0.8" />
    </command>
    <!-- volumetric light - alpha -->
    <command type="volumetriclight" vs="Volumetric/VolumetricLight" ps="Volumetric/VolumetricLight" vsdefines="BILLBOARD" psdefines="" blend="addalpha">
        <texture unit="diffuse" name="depth_buffer" />
    </command>
    <!-- 描边、高亮 -->
    <command type="sendevent" name="OutsideStroke">
    </command>
    <postprocess type="postprocess" name="EngineRes/PostProcess/EditorPostProcess.xml" />
</renderpath>